<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".ui.MainActivity">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:title="@string/app_name" />

        </com.google.android.material.appbar.AppBarLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">

            <!-- Home Tab Content -->
            <androidx.core.widget.NestedScrollView
                android:id="@+id/content_home"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Service Status Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        app:cardElevation="2dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/service_status"
                                android:textAppearance="?attr/textAppearanceHeadline6" />

                            <TextView
                                android:id="@+id/text_status"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:textAppearance="?attr/textAppearanceBody1"
                                tools:text="@string/status_stopped" />

                            <ProgressBar
                                android:id="@+id/progress_bar"
                                style="?android:attr/progressBarStyleHorizontal"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:indeterminate="true"
                                android:visibility="gone" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/button_toggle_service"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="16dp"
                                android:text="@string/start_service"
                                app:icon="@drawable/ic_play_arrow" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- Peer Connection Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        app:cardElevation="2dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/network_statistics"
                                android:textAppearance="?attr/textAppearanceHeadline6" />

                            <!-- Connection Type -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@string/connection_type"
                                    android:textAppearance="?attr/textAppearanceBody2"
                                    android:textColor="?android:attr/textColorSecondary" />

                                <TextView
                                    android:id="@+id/text_connection_type"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textAppearance="?attr/textAppearanceBody2"
                                    tools:text="WiFi" />
                            </LinearLayout>

                            <!-- Peers List Header -->
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:text="@string/configured_peers"
                                android:textAppearance="?attr/textAppearanceBody1"
                                android:textStyle="bold" />

                            <!-- Peers List Container -->
                            <LinearLayout
                                android:id="@+id/peers_container"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:orientation="vertical">

                                <!-- Peers will be added dynamically here -->

                            </LinearLayout>

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- Mail Configuration Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        app:cardElevation="2dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/mail_configuration"
                                android:textAppearance="?attr/textAppearanceHeadline6" />

                            <TextView
                                android:id="@+id/text_mail_address"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:textAppearance="?attr/textAppearanceBody2"
                                android:textIsSelectable="true"
                                android:visibility="gone"
                                tools:text="abcd1234@yggmail"
                                tools:visibility="visible" />

                            <!-- Server Info -->
                            <TextView
                                android:id="@+id/text_imap_server"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:textAppearance="?attr/textAppearanceBody2"
                                tools:text="IMAP: 127.0.0.1:1143" />

                            <TextView
                                android:id="@+id/text_smtp_server"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:textAppearance="?attr/textAppearanceBody2"
                                tools:text="SMTP: 127.0.0.1:1025" />

                            <!-- Action Buttons -->
                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/button_setup_deltachat"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="16dp"
                                android:text="@string/setup_deltachat"
                                android:visibility="gone"
                                app:icon="@drawable/ic_play_arrow"
                                tools:visibility="visible" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:orientation="horizontal">

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/button_copy_address"
                                    style="@style/Widget.MaterialComponents.Button.TextButton"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginEnd="8dp"
                                    android:text="@string/copy_address"
                                    android:visibility="gone"
                                    app:icon="@drawable/ic_play_arrow"
                                    tools:visibility="visible" />

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/button_show_qr"
                                    style="@style/Widget.MaterialComponents.Button.TextButton"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@string/show_qr_code"
                                    android:visibility="gone"
                                    app:icon="@drawable/ic_play_arrow"
                                    tools:visibility="visible" />

                            </LinearLayout>

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- Storage and Quota Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_storage_quota"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:visibility="gone"
                        app:cardElevation="2dp"
                        tools:visibility="visible">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/storage_and_quota"
                                android:textAppearance="?attr/textAppearanceHeadline6" />

                            <!-- Quota Section -->
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:text="@string/quota_usage_label"
                                android:textAppearance="?attr/textAppearanceBody1"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/text_quota_info"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="@string/loading"
                                android:textAppearance="?attr/textAppearanceBody2"
                                tools:text="Used: 2.5 MB / 10 MB (25%)" />

                            <com.google.android.material.progressindicator.LinearProgressIndicator
                                android:id="@+id/quota_info_progress"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:max="100"
                                android:progress="0"
                                app:trackThickness="6dp"
                                app:indicatorColor="?attr/colorPrimary"
                                app:trackColor="?attr/colorSurfaceVariant" />

                            <!-- Storage Statistics Section -->
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="16dp"
                                android:text="@string/storage_statistics"
                                android:textAppearance="?attr/textAppearanceBody1"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/text_storage_info"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="@string/loading"
                                android:textAppearance="?attr/textAppearanceBody2"
                                android:lineSpacingExtra="2dp"
                                tools:text="Database: 5.2 MB\nFiles: 12.8 MB\nTotal: 18.0 MB" />

                            <!-- Media Cache Section -->
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="16dp"
                                android:text="@string/media_cache_label"
                                android:textAppearance="?attr/textAppearanceBody1"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/text_media_cache_info"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="@string/loading"
                                android:textAppearance="?attr/textAppearanceBody2"
                                android:lineSpacingExtra="2dp"
                                tools:text="Chat attachments: 3.4 MB" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- DeltaChat/ArcaneChat Setup Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_deltachat_setup"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        app:cardElevation="2dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/deltachat_setup"
                                android:textAppearance="?attr/textAppearanceHeadline6" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="@string/deltachat_setup_hint"
                                android:textAppearance="?attr/textAppearanceBody2" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- Email Client Setup Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_email_client_setup"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardElevation="2dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/email_client_setup_title"
                                android:textAppearance="?attr/textAppearanceHeadline6" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="@string/email_client_setup_hint"
                                android:textAppearance="?attr/textAppearanceBody2" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

            </androidx.core.widget.NestedScrollView>

            <!-- Chat Tab Content -->
            <androidx.fragment.app.FragmentContainerView
                android:id="@+id/content_chat"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone" />

            <!-- Settings Tab Content -->
            <androidx.fragment.app.FragmentContainerView
                android:id="@+id/content_settings"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone" />

        </FrameLayout>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        style="@style/Widget.MaterialComponents.BottomNavigationView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bottom_nav_background"
        android:elevation="8dp"
        app:itemIconSize="22dp"
        app:itemIconTint="@color/nav_item_tint"
        app:itemTextColor="@color/nav_item_tint"
        app:labelVisibilityMode="selected"
        app:menu="@menu/bottom_nav_menu" />

</LinearLayout>
