<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="start"
    android:paddingVertical="3dp"
    android:paddingHorizontal="8dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="56dp"
        android:orientation="vertical"
        android:background="@drawable/bubble_received"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="6dp">

        <!-- Quote block: shown when this message is a reply -->
        <LinearLayout
            android:id="@+id/layout_quote"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone"
            android:layout_marginBottom="6dp"
            android:background="?attr/colorSurface"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:paddingStart="0dp"
            android:paddingEnd="6dp">

            <View
                android:layout_width="3dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="6dp"
                android:background="?attr/colorPrimary" />

            <TextView
                android:id="@+id/text_quote"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="2"
                android:ellipsize="end"
                android:textAppearance="?attr/textAppearanceLabelMedium"
                android:textColor="?attr/colorOnSurface"
                android:alpha="0.75"
                tools:text="Original message text here" />

        </LinearLayout>

        <!-- Attachment preview (image or file) -->
        <LinearLayout
            android:id="@+id/layout_attachment"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone"
            android:layout_marginBottom="6dp"
            android:padding="8dp">

            <ImageView
                android:id="@+id/image_attachment_thumb"
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:scaleType="centerCrop"
                android:visibility="gone"
                android:contentDescription="@string/attach_image_preview" />

            <LinearLayout
                android:id="@+id/layout_file_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:visibility="gone">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_file"
                    app:tint="?attr/colorOnSurfaceVariant"
                    android:contentDescription="@null" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:id="@+id/text_attachment_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:maxLines="1"
                        android:ellipsize="middle"
                        android:maxEms="14"
                        android:textAppearance="?attr/textAppearanceLabelMedium"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        tools:text="document.pdf" />

                    <TextView
                        android:id="@+id/text_attachment_size"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceLabelSmall"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:alpha="0.7"
                        tools:text="2.4 MB" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <TextView
            android:id="@+id/text_message_body"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceBodyLarge"
            android:lineSpacingMultiplier="1.1"
            android:textColor="?attr/colorOnSurfaceVariant"
            tools:text="Hi! How are you?" />

        <TextView
            android:id="@+id/text_message_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="3dp"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:alpha="0.7"
            tools:text="12:35" />

    </LinearLayout>

</LinearLayout>
