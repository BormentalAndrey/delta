<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Базовая тема Material Components с необходимыми атрибутами -->
    <style name="BaseAppTheme" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">#FF1976D2</item>
        <item name="colorPrimaryVariant">#FF1565C0</item>
        <item name="colorOnPrimary">#FFFFFFFF</item>
        <item name="colorSecondary">#FF388E3C</item>
        <item name="colorSecondaryVariant">#FF2E7D32</item>
        <item name="colorOnSecondary">#FFFFFFFF</item>
        <item name="android:colorBackground">#FFF5F5F5</item>
        <item name="colorSurface">#FFFFFFFF</item>
        <item name="colorOnSurface">#FF000000</item>
        <item name="colorError">#FFB00020</item>
        <item name="colorOnError">#FFFFFFFF</item>
    </style>

    <!-- Основная тема лаунчера -->
    <style name="Theme.Material3.Light" parent="BaseAppTheme" />

    <!-- Тема для DeltaChat -->
    <style name="Theme.DeltaChat" parent="BaseAppTheme" />
    
    <!-- Тема для Tyr -->
    <style name="Theme.Tyr" parent="BaseAppTheme" />
    
    <!-- Тема для Tyr Onboarding -->
    <style name="Theme.Tyr.Onboarding" parent="BaseAppTheme">
        <item name="android:windowFullscreen">true</item>
    </style>

    <!-- Splash-тема DeltaChat -->
    <style name="TextSecure.Splash" parent="BaseAppTheme">
        <item name="android:windowBackground">#FF1976D2</item>
    </style>

    <!-- Светлая тема DeltaChat -->
    <style name="TextSecure.LightTheme" parent="BaseAppTheme" />
</resources>
