<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Базовая тема Material Components со ВСЕМИ обязательными атрибутами -->
    <style name="BaseAppTheme" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Основные Material-атрибуты (обязательны для компонентов) -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/secondary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary_dark</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/black</item>
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/white</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:navigationBarColor">@color/primary</item>
    </style>

    <!-- Основная тема лаунчера -->
    <style name="Theme.Material3.Light" parent="BaseAppTheme" />

    <!-- Тема для DeltaChat -->
    <style name="Theme.DeltaChat" parent="BaseAppTheme" />
    
    <!-- Тема для Tyr -->
    <style name="Theme.Tyr" parent="BaseAppTheme" />
    
    <!-- Тема для Tyr Onboarding -->
    <style name="Theme.Tyr.Onboarding" parent="BaseAppTheme">
        <item name="android:windowFullscreen">true</item>
    </style>

    <!-- Splash-тема DeltaChat -->
    <style name="TextSecure.Splash" parent="BaseAppTheme">
        <item name="android:windowBackground">@color/primary</item>
    </style>

    <!-- Светлая тема DeltaChat -->
    <style name="TextSecure.LightTheme" parent="BaseAppTheme" />
</resources>
