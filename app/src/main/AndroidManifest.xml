<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ========== PERMISSIONS ========== -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.WRITE_CONTACTS" />
    <uses-permission android:name="android.permission.READ_SYNC_SETTINGS" />
    <uses-permission android:name="android.permission.WRITE_SYNC_SETTINGS" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    
    <!-- ========== FEATURES ========== -->
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.camera.autofocus" android:required="false" />
    <uses-feature android:name="android.hardware.location" android:required="false" />
    <uses-feature android:name="android.hardware.location.gps" android:required="false" />

    <!-- Override minSdk for libraries that require higher API -->
    <uses-sdk tools:overrideLibrary="com.jbselfcompany.tyr, go.mobile.gojni" />

    <!-- ========== APPLICATION ========== -->
    <application
        android:name="com.launcher.multiapp.TyrApplicationWrapper"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="Universal Launcher"
        android:theme="@style/Theme.Material3.Light"
        android:networkSecurityConfig="@xml/network_security_config"
        android:supportsRtl="true"
        android:largeHeap="true"
        android:requestLegacyExternalStorage="true"
        tools:replace="android:name,android:label,android:theme,android:allowBackup,android:icon">
      
        <!-- ===== LAUNCHER ACTIVITY ===== -->
        <activity
            android:name="com.launcher.multiapp.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Material3.Light">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ===== DELTACHAT ACTIVITIES ===== -->
        <activity
            android:name="com.b44t.messenger.ConversationListActivity"
            android:exported="false"
            android:configChanges="touchscreen|keyboard|keyboardHidden|orientation|screenLayout|screenSize"
            android:launchMode="singleTask"
            android:theme="@style/Theme.DeltaChat"
            tools:replace="android:theme" />

        <activity
            android:name="com.b44t.messenger.ConversationActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:configChanges="touchscreen|keyboard|keyboardHidden|orientation|screenLayout|screenSize"
            android:theme="@style/Theme.DeltaChat"
            tools:replace="android:theme" />

        <activity
            android:name="com.b44t.messenger.ProfileActivity"
            android:exported="false"
            android:theme="@style/Theme.DeltaChat"
            tools:replace="android:theme" />

        <activity
            android:name="com.b44t.messenger.SettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.DeltaChat"
            tools:replace="android:theme" />

        <activity
            android:name="com.b44t.messenger.AccountActivity"
            android:exported="false"
            android:theme="@style/Theme.DeltaChat"
            tools:replace="android:theme" />

        <activity
            android:name="com.b44t.messenger.RegistrationActivity"
            android:exported="false"
            android:theme="@style/Theme.DeltaChat"
            tools:replace="android:theme" />

        <activity
            android:name="com.b44t.messenger.Registration2ndDeviceQrActivity"
            android:exported="false"
            android:theme="@style/Theme.DeltaChat"
            tools:replace="android:theme" />

        <!-- ===== DELTACHAT SERVICES ===== -->
        <service
            android:name="com.b44t.messenger.service.ImapService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <service
            android:name="com.b44t.messenger.service.SmtpService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <service
            android:name="com.b44t.messenger.service.MvboxService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <service
            android:name="com.b44t.messenger.service.FetchService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- ===== DELTACHAT RECEIVERS ===== -->
        <receiver
            android:name="com.b44t.messenger.receiver.BootReceiver"
            android:exported="true"
            android:enabled="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <receiver
            android:name="com.b44t.messenger.receiver.ConnectivityReceiver"
            android:exported="false"
            android:enabled="true">
            <intent-filter>
                <action android:name="android.net.conn.CONNECTIVITY_CHANGE" />
            </intent-filter>
        </receiver>

        <receiver
            android:name="com.b44t.messenger.receiver.AlarmReceiver"
            android:exported="false"
            android:enabled="true" />

        <!-- ===== TYR ACTIVITIES ===== -->
        <activity
            android:name="com.jbselfcompany.tyr.ui.MainActivity"
            android:launchMode="singleTask"
            tools:replace="android:exported,android:theme,android:launchMode" />
            
        <activity
            android:name="com.jbselfcompany.tyr.ui.onboarding.OnboardingActivity"
            tools:replace="android:exported,android:theme" />
            
        <activity
            android:name="com.jbselfcompany.tyr.ui.AboutActivity"
            tools:replace="android:exported" />
            
        <activity
            android:name="com.jbselfcompany.tyr.ui.settings.SettingsActivity"
            tools:replace="android:exported" />
            
        <activity
            android:name="com.jbselfcompany.tyr.ui.logs.LogsActivity"
            tools:replace="android:exported" />
            
        <activity
            android:name="com.jbselfcompany.tyr.ui.PeersActivity"
            tools:replace="android:exported" />
            
        <activity
            android:name="com.jbselfcompany.tyr.chat.ui.ConversationActivity"
            android:windowSoftInputMode="adjustResize"
            tools:replace="android:exported,android:windowSoftInputMode" />
            
        <!-- ВАЖНО: Убираем android:screenOrientation, оставляем только tools:replace -->
        <activity
            android:name="com.journeyapps.barcodescanner.CaptureActivity"
            tools:replace="android:screenOrientation,android:exported" />

        <!-- ===== TYR SERVICES ===== -->
        <service
            android:name="com.jbselfcompany.tyr.service.YggmailService"
            android:enabled="true"
            android:stopWithTask="false"
            tools:replace="android:exported,android:foregroundServiceType" />

        <!-- ===== TYR RECEIVERS ===== -->
        <receiver
            android:name="com.jbselfcompany.tyr.receiver.BootReceiver"
            android:enabled="true"
            tools:replace="android:exported">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <receiver
            android:name="com.jbselfcompany.tyr.receiver.MaintenanceReceiver"
            android:enabled="true"
            tools:replace="android:exported" />

        <!-- ===== FILE PROVIDERS ===== -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true"
            tools:replace="android:authorities">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.dcfileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/dc_file_paths" />
        </provider>

    </application>
</manifest>
